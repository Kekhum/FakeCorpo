# ---------- Local infrastructure (docker compose) ----------
# Used by services running on host against `docker compose up`
REDIS_URL=redis://localhost:6379/0
KAFKA_BROKERS=localhost:19092
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
POSTGRES_URL=postgresql://fakecorpo:fakecorpo@localhost:5432/postgres

# ---------- orchestrator-clock ----------
CLOCK_REDIS_URL=redis://localhost:6379/0
CLOCK_KAFKA_BROKERS=localhost:19092
CLOCK_KAFKA_TOPIC_TICK=clock.tick
# Where the simulated company "starts" living
CLOCK_INITIAL_SIM_TIME=2022-01-01T00:00:00+00:00
# 1 real second = N sim seconds. 288 -> 1 sim day per 5 real minutes.
CLOCK_INITIAL_SPEED_RATIO=288
CLOCK_TICK_INTERVAL_SECONDS=1.0
CLOCK_PORT=8000

# ---------- sim-procurement ----------
PROC_DATABASE_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/db_procurement
PROC_DATABASE_BOOTSTRAP_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/postgres
PROC_DATABASE_NAME=db_procurement
PROC_KAFKA_BROKERS=localhost:19092
PROC_KAFKA_TOPIC_TICK=clock.tick
PROC_KAFKA_TOPIC_PO_CREATED=procurement.po_created
PROC_KAFKA_TOPIC_PO_ARRIVED=procurement.po_arrived
PROC_KAFKA_CONSUMER_GROUP=sim-procurement
PROC_RUN_INTERVAL_SIM_DAYS=7
PROC_ARRIVALS_INTERVAL_SIM_DAYS=1
PROC_P_INVOICE_NAME_VARIANT=0.30
PROC_P_INVOICE_IN_EUR=0.20
PROC_FX_JITTER=0.02
PROC_P_MISSING_FX_RATE=0.05
PROC_RANDOM_SEED=42

# ---------- sim-production ----------
PROD_DATABASE_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/db_production
PROD_DATABASE_BOOTSTRAP_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/postgres
PROD_DATABASE_NAME=db_production
PROD_KAFKA_BROKERS=localhost:19092
PROD_KAFKA_TOPIC_TICK=clock.tick
PROD_KAFKA_TOPIC_PO_ARRIVED=procurement.po_arrived
PROD_KAFKA_TOPIC_BATCH_STARTED=production.batch_started
PROD_KAFKA_TOPIC_BATCH_COMPLETED=production.batch_completed
PROD_KAFKA_TOPIC_TELEMETRY=production.roaster_telemetry
PROD_KAFKA_CONSUMER_GROUP=sim-production
PROD_ROASTING_DECISION_INTERVAL_SIM_DAYS=1
PROD_MIN_BATCHES_PER_DAY=3
PROD_MAX_BATCHES_PER_DAY=8
PROD_BATCH_SIZE_MIN_KG=50
PROD_BATCH_SIZE_MAX_KG=200
PROD_ROAST_DURATION_SIM_SECONDS=720
PROD_TELEMETRY_SAMPLE_INTERVAL_SIM_SECONDS=10
PROD_RANDOM_SEED=99

# ---------- sim-pos-cafes ----------
POS_DATABASE_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/db_pos
POS_DATABASE_BOOTSTRAP_URL=postgresql+asyncpg://fakecorpo:fakecorpo@localhost:5432/postgres
POS_DATABASE_NAME=db_pos
POS_KAFKA_BROKERS=localhost:19092
POS_KAFKA_TOPIC_TICK=clock.tick
POS_KAFKA_TOPIC_TRANSACTION=pos.transaction_completed
POS_KAFKA_CONSUMER_GROUP=sim-pos-cafes
POS_MAX_HOURS_PER_TICK=24
POS_PAYMENT_CARD_SHARE=0.70
POS_RANDOM_SEED=7

# ---------- fakecorpo-cli ----------
FAKECORPO_API_URL=http://localhost:8000
